# Production env example for Render. Copy values into Render dashboard.
# Do NOT commit a real .env file with secrets.

# Required: MongoDB Atlas connection string (with password URL-encoded if needed)
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name (any name; will be auto-created)
DB_NAME=ievaldivia

# Initial admin password. Admin can change it later from the panel.
ADMIN_PASSWORD=12
